PORT=3000

# APG Day-Ahead Price API settings
APG_BASE_URL=https://transparency.apg.at/api
APG_LANGUAGE=English
APG_RESOLUTION=PT15M
# Always use the current day in this project.
APG_DAY_OFFSET=0

# Secret to protect /api/check (used by GitHub Actions)
WEBSITE_CHECK_SECRET=change-this-secret

# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-public-key
VAPID_PRIVATE_KEY=your-private-key
VAPID_SUBJECT=mailto:admin@example.com
